{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 26,
  "modules-left": ["custom/omarchy", "custom/idle-lock", "custom/notification-toggle", "hyprland/workspaces"],
  "modules-center": [],
  "modules-right": [
    "group/tray-expander",
    "network",
    "custom/sep",
    "memory",
    "custom/sep",
    "cpu",
    "custom/power-draw",
    "custom/sep",
    "custom/temperature",
    "custom/sep",
    "custom/screen",
    "custom/sep",
    "custom/power-profile",
    "custom/sep",
    "pulseaudio",
    "custom/sep",
    "bluetooth",
    "custom/sep",
    "battery",
    "custom/sep",
    "clock",
    "custom/dictation-indicator",
    "custom/screenrecording-indicator",
    "custom/update"
  ],
  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{name}"
  },
  "custom/omarchy": {
    "format": "<span font='omarchy'>\ue900</span>",
    "on-click": "omarchy-menu",
    "on-click-right": "xdg-terminal-exec",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },
  "custom/update": {
    "format": "",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 43200
  },

  "cpu": {
    "interval": 5,
    "format": "󰍛 {load}",
    "tooltip": true,
    "tooltip-format": "1min load: {load}\nUsage: {usage}%\nFrequency: {avg_frequency}GHz",
    "on-click": "xdg-terminal-exec btop"
  },
  "custom/power-draw": {
    "exec": "~/.config/waybar/scripts/power-draw.sh",
    "return-type": "json",
    "interval": 10,
    "on-click": "xdg-terminal-exec btop"
  },
  "memory": {
    "interval": 5,
    "format": "󰘚 {used:0.0f}/{swapUsed:0.0f}",
    "tooltip-format": "RAM: {used:0.1f}GiB / {total:0.1f}GiB ({percentage}%)\nSwap: {swapUsed:0.1f}GiB / {swapTotal:0.1f}GiB ({swapPercentage}%)",
    "on-click": "xdg-terminal-exec btop"
  },
  "custom/temperature": {
    "exec": "~/.config/waybar/scripts/temperatures.sh",
    "return-type": "json",
    "interval": 10,
    "on-click": "xdg-terminal-exec btop"
  },
  "clock": {
    "format": "{:%a %b %d %I:%M%p}",
    "format-alt": "{:L%d %B W%V %Y}",
    "tooltip": false,
    "on-click-right": "omarchy-launch-floating-terminal-with-presentation omarchy-tz-select"
  },
  "network": {
    "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
    "format": "{icon} {ipaddr}",
    "format-wifi": "{icon} {ipaddr}",
    "format-ethernet": "󰀂 {ipaddr}",
    "format-disconnected": "󰤮",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
    "tooltip-format-ethernet": "⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 10,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },
  "custom/power-profile": {
    "exec": "~/.config/waybar/scripts/power-profile-status.sh",
    "return-type": "json",
    "interval": 10,
    "signal": 13,
    "on-click": "~/.config/waybar/scripts/power-profile-toggle.sh",
    "tooltip": true
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {power:.1f}W↓ {icon}",
    "format-charging": "{capacity}% {power:.1f}W↑ {icon}",
    "format-plugged": "",
    "format-icons": {
      "charging": ["󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"],
      "default": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },
    "format-full": "󰂅",
    "tooltip-format-discharging": "{time} remaining",
    "tooltip-format-charging": "{time} until full",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "",
    "format-disabled": "󰂲",
    "format-connected": "󰂱",
    "format-no-controller": "󰂲",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },
  "pulseaudio": {
    "format": "{icon}",
    "on-click": "xdg-terminal-exec --app-id=com.omarchy.Wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "",
    "format-icons": {
      "headphone": "",
      "headset": "",
      "default": ["", "", ""]
    }
  },
  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },
  "custom/expand-icon": {
    "format": "",
    "tooltip": false
  },
  "custom/screenrecording-indicator": {
    "on-click": "omarchy-cmd-screenrecord",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },
  "custom/dictation-indicator": {
    "on-click": "~/.config/hypr/scripts/dictate.sh",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/dictation.sh",
    "signal": 11,
    "return-type": "json"
  },
  "custom/idle-lock": {
    "exec": "~/.config/waybar/scripts/idle-lock-status.sh",
    "on-click": "omarchy-toggle-idle",
    "return-type": "json",
    "signal": 9
  },
  "custom/notification-toggle": {
    "exec": "~/.config/waybar/scripts/notification-status.sh",
    "on-click": "~/.config/waybar/scripts/toggle-notifications.sh",
    "return-type": "json",
    "signal": 12
  },
  "custom/sep": {
    "format": "|",
    "tooltip": false
  },
  "custom/screen": {
    "exec": "~/.config/waybar/scripts/screen-status.sh",
    "return-type": "json",
    "signal": 10,
    "on-click": "~/.config/waybar/scripts/toggle-refresh-rate.sh"
  },
  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "󰍬",
      "transcribing": "󰔟"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },
  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },
  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },
  "tray": {
    "icon-size": 12,
    "spacing": 17
  }
}
